# AI Daily Brief — crontab example
# Install: crontab -e , paste lines below (adjust paths)

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# Timezone for 08:00 Beijing
TZ=Asia/Shanghai

# Weekdays 08:00 — full pipeline with log file
0 8 * * 1-5 cd /Users/yanxin/Desktop/AI_Daily_Brief && ./venv/bin/python -m ai_news_bot.main --log-file logs/brief.log >> logs/cron.log 2>&1

# Optional: Saturday dry-run health check (no OpenAI cost if --dry-run)
# 0 9 * * 6 cd /Users/yanxin/Desktop/AI_Daily_Brief && ./venv/bin/python -m ai_news_bot.main --dry-run >> logs/health.log 2>&1
